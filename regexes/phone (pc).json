{
  "name": "phone",
  "description": "Hogwarts Letter Final Build",
  "scripts": [
    {
      "id": "ph-open",
      "scriptName": "┌ phone open (The Master Letter)",
      "findRegex": "/<ph>([^|]+)\\|([^|]+)\\|([^\\n<]+)([\\s\\S]+?)<\\/ph>/g",
      "replaceString": "<style>@import url('https://fonts.googleapis.com/css2?family=Marck+Script&family=Pangolin&display=swap'); .letter-wrap{position:relative;width:100%;max-width:420px;margin:100px auto 140px auto;filter:drop-shadow(0 20px 40px rgba(0,0,0,0.6))}.envelope-back{position:absolute;bottom:-100px;left:0;width:100%;height:220px;background:#b3967a;border-radius:0 0 10px 10px;border:1px solid #8e765d;z-index:0;box-shadow:inset 0 20px 40px rgba(0,0,0,0.3)}.envelope-back::before{content:'';position:absolute;top:0;left:0;width:100%;height:100%;background:linear-gradient(155deg, #c4a484 50%, #a68b6d 50%);z-index:1;clip-path:polygon(0 0, 50% 45%, 100% 0, 100% 100%, 0 100%);border-radius:0 0 10px 10px}.envelope-flap-top{position:absolute;top:-75px;left:0;width:0;height:0;border-left:210px solid transparent;border-right:210px solid transparent;border-bottom:80px solid #c4a484;z-index:0}.letter-paper{background:#f2e3bc;background-image:url('https://www.transparenttextures.com/patterns/old-map.png');color:#2a1e16 !important;padding:70px 35px 60px 35px;font-family:'Marck Script', cursive !important;font-size:1.4em !important;border-radius:2px;box-shadow:inset 0 0 80px rgba(139,105,79,0.4), 5px 5px 15px rgba(0,0,0,0.1);position:relative;z-index:2;border:1px solid #d4b483;line-height:1.4 !important;transform:translateY(-15px)}.letter-header{font-family:'Marck Script', cursive !important;font-size:1.8em !important;text-align:center;margin-bottom:35px;color:#5e4433 !important;border-bottom:1px double rgba(94,68,51,0.3);padding-bottom:10px}.letter-seal-top{position:absolute;top:-45px;left:50%;transform:translateX(-50%);width:80px;height:80px;background:radial-gradient(circle, #a30000 0%, #7a0000 100%);border-radius:50%;border:2px solid #5a0000;box-shadow:0 8px 15px rgba(0,0,0,0.6);display:flex;align-items:center;justify-content:center;z-index:10}.letter-seal-inner{width:85%;height:85%;border:2px double rgba(244,228,188,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center}.letter-seal-inner::after{content:'🦉';font-size:2em;opacity:0.4;filter:brightness(0.3)}.letter-content img{display:block;margin:35px auto;border-radius:5px;border:1px solid #d4b483;box-shadow:0 10px 25px rgba(0,0,0,0.4);max-width:95%}.sig-font{font-family:'Marck Script', cursive !important;font-size:1.1em !important;text-align:right;margin-top:15px;color:#5e4433 !important;display:block}</style><div class='letter-wrap'><div class='envelope-flap-top'></div><div class='letter-seal-top'><div class='letter-seal-inner'></div></div><div class='letter-paper'><div class='letter-header'>Письмо для $1</div><div class='letter-content'>$4</div></div><div class='envelope-back'></div></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-ms-logic",
      "scriptName": "├ MS logic",
      "findRegex": "/<(?:ms|lk|nt|ig|tw)>([^|\\n<]*)\\|?([^|\\n<]*)([\\s\\S]+?)<\\/(?:ms|lk|nt|ig|tw)>/g",
      "replaceString": "<div style='margin-bottom:45px'>$3</div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-msg-in",
      "scriptName": "├ incoming message",
      "findRegex": "/MST<\\|([^|]*)\\|([^<\\n]+)/g",
      "replaceString": "<div style='margin-bottom:30px'>«$2»<span class='sig-font'>Сатору, $1</span></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-msg-out",
      "scriptName": "├ outgoing message",
      "findRegex": "/MST>\\|([^|]*)\\|[^|]*\\|([^<\\n]+)/g",
      "replaceString": "<div style='margin-bottom:30px; border-top:1px dashed rgba(61,43,31,0.1); padding-top:20px'>$2<span class='sig-font'>Сон Джинву, $1</span></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    }
  ]
}
