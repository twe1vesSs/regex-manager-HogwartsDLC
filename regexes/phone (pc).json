{
  "name": "phone",
  "description": "Hogwarts Letter Final Edition",
  "scripts": [
    {
      "id": "ph-open",
      "scriptName": "┌ phone open (The Letter)",
      "findRegex": "/<ph>([^|]+)\\|([^|]+)\\|([^\\n<]+)([\\s\\S]+?)<\\/ph>/g",
      "replaceString": "<style>@import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,700;1,400&family=Great+Vibes&display=swap'); .letter-wrap{position:relative;width:100%;max-width:420px;margin:60px auto;filter:drop-shadow(0 15px 25px rgba(0,0,0,0.4))}.letter-paper{background:#f2e3bc;background-image:url('https://www.transparenttextures.com/patterns/old-map.png');color:#3d2b1f;padding:60px 30px 40px 30px;font-family:'Crimson Text',serif;border-radius:3px;box-shadow:inset 0 0 60px rgba(139,105,79,0.3);position:relative;z-index:1;border:1px solid #d4b483}.letter-header{font-family:'Great Vibes',cursive;font-size:2.4em;text-align:center;margin-bottom:30px;color:#5e4433;line-height:1.2}.letter-seal-top{position:absolute;top:-30px;left:50%;transform:translateX(-50%);width:65px;height:65px;background:#8b0000;border-radius:50%;border:3px solid #660000;box-shadow:0 4px 10px rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;z-index:3}.letter-seal-inner{width:80%;height:80%;border:1px solid rgba(244,228,188,0.4);border-radius:50%;display:flex;align-items:center;justify-content:center}.letter-seal-inner::after{content:'📜';font-size:1.5em;filter:sepia(1) saturate(0.5) brightness(1.5)}.letter-content img{display:block;margin:20px auto;border-radius:5px;border:1px solid #d4b483;box-shadow:0 5px 15px rgba(0,0,0,0.2);max-width:100%}</style><div class='letter-wrap'><div class='letter-seal-top'><div class='letter-seal-inner'></div></div><div class='letter-paper'><div class='letter-header'>Письмо для $1</div><div class='letter-content'>$4</div></div></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-ms-logic",
      "scriptName": "├ MS logic (No scrolls)",
      "findRegex": "/<(?:ms|lk|nt|ig|tw)>([^|\\n<]*)\\|?([^|\\n<]*)([\\s\\S]+?)<\\/(?:ms|lk|nt|ig|tw)>/g",
      "replaceString": "<div class='ms-block' style='margin-bottom:30px'>$3</div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-msg-in",
      "scriptName": "├ incoming message (MST<)",
      "findRegex": "/MST<\\|([^|]*)\\|([^<\\n]+)/g",
      "replaceString": "<div style='margin-bottom:20px'><div style='font-style:italic;margin-bottom:5px'>«$2»</div><div style='text-align:right;font-family:\"Great Vibes\", cursive; font-size:1.1em; opacity:0.8'>Сатору, $1</div></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-msg-out",
      "scriptName": "├ outgoing message (MST>)",
      "findRegex": "/MST>\\|([^|]*)\\|[^|]*\\|([^<\\n]+)/g",
      "replaceString": "<div style='margin-bottom:20px;border-top:1px dashed rgba(61,43,31,0.1);padding-top:10px'><div>$2</div><div style='text-align:right;font-family:\"Great Vibes\", cursive; font-size:1.1em; opacity:0.8'>Сон Джинву, $1</div></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-nf-logic",
      "scriptName": "├ notification (NF|)",
      "findRegex": "/»NF\\|[^|]*\\|([^|]*)\\|([^|]*)\\|([^|]*)\\|([^<\\n]+)/g",
      "replaceString": "<div style='margin:20px 0;padding:15px;background:rgba(0,0,0,0.03);border:1px solid rgba(61,43,31,0.1)'><i>$4</i><div style='text-align:right;font-size:0.9em;opacity:0.6'>— $2 ($3)</div></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-clean-tail",
      "scriptName": "└ clean tail (M~)",
      "findRegex": "/M~\\|/g",
      "replaceString": "",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    }
  ]
}
