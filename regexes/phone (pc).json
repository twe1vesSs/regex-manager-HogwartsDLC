{
  "name": "phone",
  "description": "Hogwarts Letter Transformation",
  "scripts": [
    {
      "id": "ph-clean-quotes",
      "scriptName": "┌ phone clean quotes",
      "findRegex": "/((?:M[<>]|MST[<>]|MSI[<>]|NF)\\|[^|]*\\|)\"([^\"]+)\"/g",
      "replaceString": "$1$2",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-open",
      "scriptName": "├ phone open",
      "findRegex": "/<ph>([^|]+)\\|([^|]+)\\|([\\s\\S]+?)<\\/ph>/g",
      "replaceString": "<style>@import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,700;1,400&family=Great+Vibes&display=swap'); .letter-body{background:#f4e4bc;background-image:url('https://www.transparenttextures.com/patterns/old-map.png');color:#3d2b1f;padding:40px 30px;font-family:'Crimson Text',serif;border-radius:2px;box-shadow:0 0 20px rgba(0,0,0,0.5), inset 0 0 100px rgba(139,105,79,0.3);position:relative;border:1px solid #d4b483;margin:20px 0;line-height:1.6}.letter-header{font-family:'Great Vibes',cursive;font-size:2.2em;text-align:center;margin-bottom:20px;border-bottom:1px double #3d2b1f;padding-bottom:10px}.letter-seal{position:absolute;bottom:-20px;right:20px;width:60px;height:60px;background:#8b0000;border-radius:50%;box-shadow:2px 2px 5px rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;color:#f4e4bc;font-weight:bold;border:3px solid #660000;z-index:10;transform:rotate(-15deg);font-size:0.8em;text-align:center;line-height:1}</style><div class='letter-body'><div class='letter-header'>$1</div><div class='letter-content'>$3</div><div class='letter-seal'>🦉<br>HOGWARTS</div></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-msg-incoming",
      "scriptName": "├ message incoming",
      "findRegex": "/M<\\|([^|]*)\\|([^<]+)/g",
      "replaceString": "<div style='margin-bottom:15px;border-left:2px solid #3d2b1f;padding-left:10px'><b style='font-family:\"Great Vibes\", cursive; font-size:1.2em'>$1:</b><br><span style='font-style:italic'>«$2»</span></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-msg-outgoing",
      "scriptName": "├ message outgoing",
      "findRegex": "/M>\\|([^|]*)\\|([^<]+)/g",
      "replaceString": "<div style='margin-bottom:15px;text-align:right;border-right:2px solid #8b0000;padding-right:10px'><b style='font-family:\"Great Vibes\", cursive; font-size:1.2em'>Вы:</b><br><span>$2</span></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-nt-open",
      "scriptName": "├ notes open",
      "findRegex": "/<nt>([\\s\\S]*?)<\\/nt>/g",
      "replaceString": "<div style='background:rgba(0,0,0,0.05);padding:15px;border:1px dashed #3d2b1f;margin-top:20px;font-size:0.9em'><center>📜 <b>Приписка на полях:</b></center><br>$1</div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-nt-item",
      "scriptName": "├ notes item",
      "findRegex": "/(<nt>[\\s\\S]*?)^\\*\\s*(.+)$([\\s\\S]*?<\\/nt>)/gm",
      "replaceString": "$1<div style='display:flex;align-items:center;gap:8px;margin:5px 0'><span style='color:#8b0000'>✒️</span> $2</div>$3",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    }
  ]
}
