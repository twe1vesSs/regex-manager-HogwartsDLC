{
  "name": "phone",
  "description": "Hogwarts Letter Ultimate Edition",
  "scripts": [
    {
      "id": "ph-open",
      "scriptName": "┌ phone open (The Letter & Envelope)",
      "findRegex": "/<ph>([^|]+)\\|([^|]+)\\|([^\\n<]+)([\\s\\S]+?)<\\/ph>/g",
      "replaceString": "<style>@import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,700;1,400&family=Great+Vibes&family=Charm:wght@400;700&display=swap'); .letter-wrap{position:relative;width:100%;max-width:420px;margin:80px auto;filter:drop-shadow(0 15px 25px rgba(0,0,0,0.4))}.envelope-back{background:#b3967a;height:120px;border-radius:0 0 10px 10px;position:relative;z-index:0;margin-top:-110px;border:1px solid #8e765d;box-shadow:inset 0 10px 20px rgba(0,0,0,0.2)}.letter-paper{background:#f2e3bc;background-image:url('https://www.transparenttextures.com/patterns/old-map.png');color:#3d2b1f;padding:60px 30px 40px 30px;font-family:'Charm', cursive;font-size:1.1em;border-radius:3px;box-shadow:inset 0 0 60px rgba(139,105,79,0.3);position:relative;z-index:1;border:1px solid #d4b483;transform:translateY(-10px)}.letter-header{font-family:'Great Vibes', cursive;font-size:2.5em;text-align:center;margin-bottom:30px;color:#5e4433;line-height:1.2;font-style:normal}.letter-seal-top{position:absolute;top:-35px;left:50%;transform:translateX(-50%);width:70px;height:70px;background:radial-gradient(circle, #a30000 0%, #7a0000 100%);border-radius:50%;border:2px solid #5a0000;box-shadow:0 4px 10px rgba(0,0,0,0.6);display:flex;align-items:center;justify-content:center;z-index:3}.letter-seal-inner{width:80%;height:80%;border:2px double rgba(244,228,188,0.3);border-radius:50%;display:flex;align-items:center;justify-content:center}.letter-seal-inner::after{content:'📜';font-size:1.6em;opacity:0.6;filter:brightness(0.5)}.letter-content img{display:block;margin:25px auto;border-radius:4px;border:1px solid #d4b483;box-shadow:0 5px 15px rgba(0,0,0,0.2);max-width:100%}.sig-font{font-family:'Great Vibes', cursive; font-size:1.3em; opacity:0.9; font-style:normal}</style><div class='letter-wrap'><div class='letter-seal-top'><div class='letter-seal-inner'></div></div><div class='letter-paper'><div class='letter-header'>Письмо для $1</div><div class='letter-content'>$4</div></div><div class='envelope-back'></div></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-ms-logic",
      "scriptName": "├ MS logic",
      "findRegex": "/<(?:ms|lk|nt|ig|tw)>([^|\\n<]*)\\|?([^|\\n<]*)([\\s\\S]+?)<\\/(?:ms|lk|nt|ig|tw)>/g",
      "replaceString": "<div style='margin-bottom:35px'>$3</div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-msg-in",
      "scriptName": "├ incoming message (MST<)",
      "findRegex": "/MST<\\|([^|]*)\\|([^<\\n]+)/g",
      "replaceString": "<div style='margin-bottom:20px; font-style: italic;'>«$2»<div style='text-align:right' class='sig-font'>Сатору, $1</div></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-msg-out",
      "scriptName": "├ outgoing message (MST>)",
      "findRegex": "/MST>\\|([^|]*)\\|[^|]*\\|([^<\\n]+)/g",
      "replaceString": "<div style='margin-bottom:20px; border-top:1px dashed rgba(61,43,31,0.1); padding-top:15px'>$2<div style='text-align:right' class='sig-font'>Сон Джинву, $1</div></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-nf-logic",
      "scriptName": "├ notification (NF|)",
      "findRegex": "/»NF\\|[^|]*\\|([^|]*)\\|([^|]*)\\|([^|]*)\\|([^<\\n]+)/g",
      "replaceString": "<div style='margin:25px 0; padding:15px; background:rgba(0,0,0,0.02); border:1px solid rgba(61,43,31,0.1); font-style: italic;'>$4<div style='text-align:right' class='sig-font'>$2 ($3)</div></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-clean-tail",
      "scriptName": "└ clean tail",
      "findRegex": "/M~\\|/g",
      "replaceString": "",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    }
  ]
}
