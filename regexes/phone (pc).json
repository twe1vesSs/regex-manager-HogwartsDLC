{
  "name": "phone",
  "description": "Hogwarts Letter Full Conversion",
  "scripts": [
    {
      "id": "ph-open",
      "scriptName": "┌ phone open (The Envelope)",
      "findRegex": "/<ph>([^|]+)\\|([^|]+)\\|([^\\n<]+)([\\s\\S]+?)<\\/ph>/g",
      "replaceString": "<style>@import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,700;1,400&family=Charm:wght@400;700&display=swap'); .letter-wrap{position:relative;width:100%;max-width:420px;margin:50px auto;filter:drop-shadow(0 15px 25px rgba(0,0,0,0.4))}.envelope-back{background:#b3967a;height:120px;border-radius:0 0 10px 10px;position:relative;z-index:0;margin-top:-100px;border:1px solid #8e765d;box-shadow:inset 0 10px 20px rgba(0,0,0,0.2)}.envelope-flap{position:absolute;top:-60px;left:0;width:0;height:0;border-left:210px solid transparent;border-right:210px solid transparent;border-bottom:70px solid #c4a484;z-index:0}.letter-paper{background:#f2e3bc;background-image:url('https://www.transparenttextures.com/patterns/old-map.png');color:#3d2b1f;padding:40px 30px;font-family:'Crimson Text',serif;border-radius:3px;box-shadow:inset 0 0 60px rgba(139,105,79,0.3), 2px 2px 10px rgba(0,0,0,0.1);position:relative;z-index:1;border:1px solid #d4b483;transform:translateY(-20px);transition:all 0.3s}.letter-header{font-family:'Charm',cursive;font-size:1.6em;text-align:center;border-bottom:1px double #3d2b1f;margin-bottom:20px;padding-bottom:10px;color:#5e4433}.letter-footer{margin-top:20px;text-align:right;font-family:'Charm',cursive;font-size:1.2em;border-top:1px solid rgba(61,43,31,0.2);padding-top:10px}.letter-seal{position:absolute;bottom:-30px;left:50%;transform:translateX(-50%);width:55px;height:55px;background:#8b0000;border-radius:50%;border:3px solid #660000;box-shadow:0 4px 8px rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;color:#f4e4bc;font-size:1.4em;z-index:3;cursor:default}.app-label{display:block;text-align:center;text-transform:uppercase;letter-spacing:2px;font-size:0.7em;margin-bottom:15px;color:#8b4513;opacity:0.8}</style><div class='letter-wrap'><div class='envelope-flap'></div><div class='letter-paper'><div class='letter-header'>Из переписки: $1</div><div class='letter-content'>$4</div><div class='letter-footer'>Принято совой в $2</div></div><div class='envelope-back'></div><div class='letter-seal'>H</div></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-ms-logic",
      "scriptName": "├ MS/LK/NT/IG Converter",
      "findRegex": "/<(?:ms|lk|nt|ig|tw)>([^|\\n<]*)\\|?([^|\\n<]*)([\\s\\S]+?)<\\/(?:ms|lk|nt|ig|tw)>/g",
      "replaceString": "<span class='app-label'>— Свиток $1 —</span>$3",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-msg-in",
      "scriptName": "├ incoming message (MST<)",
      "findRegex": "/MST<\\|[^|]*\\|([^<\\n]+)/g",
      "replaceString": "<div style='margin-bottom:15px;font-style:italic;padding-left:15px;border-left:1px solid #8b4513'>«$1»</div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-msg-out",
      "scriptName": "├ outgoing message (MST>)",
      "findRegex": "/MST>\\|[^|]*\\|[^|]*\\|([^<\\n]+)/g",
      "replaceString": "<div style='margin-bottom:15px;text-align:right;padding-right:15px;border-right:1px solid #3d2b1f;color:#2a1e16'>$1</div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-nf-logic",
      "scriptName": "├ notification (NF|)",
      "findRegex": "/»NF\\|[^|]*\\|([^|]*)\\|[^|]*\\|([^|]*)\\|([^<\\n]+)/g",
      "replaceString": "<div style='background:rgba(139,69,19,0.05);padding:10px;border:1px dashed #8b4513;margin:10px 0;font-size:0.9em'><b>Срочная весть от $2 ($1):</b><br>$3</div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-notes-items",
      "scriptName": "├ notes items (check/uncheck)",
      "findRegex": "/^\\s*\\[(x|\\s*)\\]\\s*(.+)$/gm",
      "replaceString": "<div style='margin-left:10px'>$1$2</div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    },
    {
      "id": "ph-clean-tail",
      "scriptName": "└ clean tail (M~)",
      "findRegex": "/M~\\|/g",
      "replaceString": "<div style='text-align:center;opacity:0.4'>✒️...</div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0
    }
  ]
}
