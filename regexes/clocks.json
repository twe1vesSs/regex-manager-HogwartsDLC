{
  "name": "clocks",
  "description": "Magical Hogwarts Clocks — Золото и бордо",
  "scripts": [
    {
      "id": "b78aa039-bcbb-4126-a847-195acd852d60",
      "scriptName": "┌ clocks",
      "findRegex": "/<info>\\s*([^|]+?)\\s*\\|\\s*([^|]+?)\\s*\\|\\s*([^|]+?)\\s*\\|\\s*([^|]+?)\\s*\\|\\s*([^§¶]+?)\\s*(§[\\s\\S]+?)\\s*(¶[^<]+)<\\/info>/gi",
      "replaceString": "<style>.clk{position:relative;background:linear-gradient(160deg,#1a1612,#2c2419);color:#e2d1a6;font-family:'Crimson Text',serif;padding:20px;border-radius:15px;box-shadow:inset 0 0 30px rgba(0,0,0,0.8), 0 0 20px rgba(255,183,77,0.1);border:1px solid #5c4a33;overflow:visible}.candle{position:absolute;width:8px;height:25px;background:#fffbe6;border-radius:2px;box-shadow:0 0 10px rgba(255,214,106,0.5);animation:float 4s ease-in-out infinite}.candle::after{content:'';position:absolute;top:-8px;left:50%;transform:translateX(-50%);width:4px;height:8px;background:#ff9800;border-radius:50% 50% 20% 20%;filter:blur(1px);animation:flicker 0.1s infinite alternate}@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-15px)}}@keyframes flicker{0%{opacity:0.8;transform:translateX(-50%) scale(1)}100%{opacity:1;transform:translateX(-50%) scale(1.2)}}.c1{top:-15px;left:10%;animation-delay:0s}.c2{top:-25px;right:15%;animation-delay:1s}.c3{bottom:-15px;left:20%;animation-delay:2s}.c4{bottom:-20px;right:10%;animation-delay:0.5s}.clk-header{display:flex;justify-content:space-between;align-items:baseline;border-bottom:1px solid rgba(226,209,166,0.3);margin-bottom:10px;padding-bottom:5px}.clk-time{font-size:1.8em;font-weight:bold;color:#ffb74d;text-shadow:0 0 10px rgba(255,183,77,0.4)}</style><div class='clk'><div class='candle c1'></div><div class='candle c2'></div><div class='candle c3'></div><div class='candle c4'></div><div class='clk-header'><span style='font-variant:small-caps'>$1, $2</span><span class='clk-time'>$5</span></div><div style='display:flex;gap:10px;margin-bottom:8px'><span style='color:#ffb74d'>🏰</span> $3 <span style='color:#ffb74d'>✨</span> $4</div><div style='font-style:italic;color:#a69575'>$6 $7</div></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0,
      "minDepth": null,
      "maxDepth": null
    },
    {
      "id": "2306f5dd-48b9-4dd7-826d-b53bf7a10b26",
      "scriptName": "├ clocks outfit",
      "findRegex": "/§\\s*([^:]+?)\\s*:\\s*([^§¶<]+)/g",
      "replaceString": "<div class=\"clk-out\"><span style=\"color:#c9a227; font-weight:bold;\">$1:</span> <span style=\"color:#b8b0a8\">$2</span></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0,
      "minDepth": null,
      "maxDepth": null
    },
    {
      "id": "ff20beaf-c8cd-44e9-9004-d84f7b121bea",
      "scriptName": "└ clocks scene",
      "findRegex": "/¶\\s*([^:]+?)\\s*:\\s*([^§¶<]+)/gi",
      "replaceString": "<div class=\"clk-sc\"><span style=\"color:#a84a5a;font-weight:bold\">$1:</span> <span style=\"color:#b8b0a8;font-style:italic\">$2</span></div>",
      "trimStrings": [],
      "placement": [1, 2, 6],
      "disabled": false,
      "markdownOnly": true,
      "promptOnly": false,
      "runOnEdit": true,
      "substituteRegex": 0,
      "minDepth": null,
      "maxDepth": null
    }
  ]
}
